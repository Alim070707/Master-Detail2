<Window x:Class="EmployeeManagerMVVM.Views.DetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EmployeeManagerMVVM.Views"
        Title="Редактирование сотрудника" 
        Height="450" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <local:StringToVisibilityConverter x:Key="StringToVisibility"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="✏️ Данные сотрудника" 
                   FontSize="18" 
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="ФИО:" FontWeight="Bold" Margin="0,5"/>
        <TextBox Grid.Row="2" 
                 Text="{Binding CurrentEmployee.FullName, UpdateSourceTrigger=PropertyChanged}"
                 Padding="5"
                 Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Text="Должность:" FontWeight="Bold" Margin="0,5"/>
        <TextBox Grid.Row="4" 
                 Text="{Binding CurrentEmployee.Position, UpdateSourceTrigger=PropertyChanged}"
                 Padding="5"
                 Margin="0,0,0,10"/>

        <TextBlock Grid.Row="5" Text="Отдел:" FontWeight="Bold" Margin="0,5"/>
        <TextBox Grid.Row="6" 
                 Text="{Binding CurrentEmployee.Department, UpdateSourceTrigger=PropertyChanged}"
                 Padding="5"
                 Margin="0,0,0,10"/>

        <TextBlock Grid.Row="7" Text="Возраст:" FontWeight="Bold" Margin="0,5"/>
        <TextBox Grid.Row="8" 
                 Text="{Binding CurrentEmployee.Age, UpdateSourceTrigger=PropertyChanged}"
                 Padding="5"
                 Margin="0,0,0,10"/>

        <TextBlock Grid.Row="9" 
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   FontSize="11"
                   Margin="0,5"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="💾 Сохранить" 
                    Command="{Binding SaveCommand}"
                    Width="100" Margin="5"
                    Background="#4CAF50" Foreground="White"
                    Cursor="Hand"/>

            <Button Content="❌ Отмена" 
                    Command="{Binding CancelCommand}"
                    Width="100" Margin="5"
                    Background="#9E9E9E" Foreground="White"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>