<Window x:Class="EmployeeManagerMVVM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление сотрудниками - Master Detail" 
        Height="500" 
        Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="📋 Список сотрудников" 
                   FontSize="20" 
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- Поиск -->
        <Border Grid.Row="1" 
                Background="#F0F0F0" 
                Padding="10" 
                Margin="0,0,0,10"
                CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔍 Поиск: " VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Width="300"
                         ToolTip="Введите ФИО, должность или отдел"/>
                <TextBlock Text="💡 Поиск работает в реальном времени" 
                           Margin="20,0,0,0" 
                           Foreground="Gray"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- DataGrid (Master) -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding FilteredEmployees}"
                  SelectedItem="{Binding SelectedEmployee}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="0,0,0,10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="150"/>
                <DataGridTextColumn Header="Отдел" Binding="{Binding Department}" Width="150"/>
                <DataGridTextColumn Header="Возраст" Binding="{Binding Age}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="➕ Добавить" 
                    Command="{Binding AddCommand}"
                    Width="100" Margin="5"
                    Background="#4CAF50" Foreground="White"
                    Cursor="Hand"/>

            <Button Content="✏️ Редактировать" 
                    Command="{Binding EditCommand}"
                    Width="100" Margin="5"
                    Background="#2196F3" Foreground="White"
                    Cursor="Hand"/>

            <Button Content="❌ Удалить" 
                    Command="{Binding DeleteCommand}"
                    Width="100" Margin="5"
                    Background="#F44336" Foreground="White"
                    Cursor="Hand"/>

            <Button Content="💾 Сохранить в JSON" 
                    Command="{Binding SaveToFileCommand}"
                    Width="120" Margin="5"
                    Background="#FF9800" Foreground="White"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>